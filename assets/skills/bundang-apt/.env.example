# 이 파일을 복사하여 .env로 만들고 실제 값을 채워주세요.
# cp .env.example .env
#
# .env 파일은 .gitignore에 포함되어 있어 git에 커밋되지 않습니다.

# Gmail API (Google Cloud Console에서 OAuth 클라이언트 발급 후 채움)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# (선택) 국토부 공공데이터포털 실거래가 API 서비스키
# data.go.kr에서 "국토교통부_아파트 매매 실거래가 자료" 활용신청 후 발급
MOLIT_SERVICE_KEY=

# 보고서 발송 대상 이메일
REPORT_RECIPIENT_EMAIL=
