{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature List",
  "description": "F&B 프랜차이즈 본사 매뉴얼 작업 마스터 리스트",
  "type": "object",
  "required": ["schema_version", "project", "stats", "generators", "tasks"],
  "properties": {
    "schema_version": { "type": "string" },
    "project": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" },
    "stats": {
      "type": "object",
      "required": ["total", "done", "pending"],
      "properties": {
        "total": { "type": "integer" },
        "done": { "type": "integer" },
        "in_progress": { "type": "integer" },
        "eval_pending": { "type": "integer" },
        "rework": { "type": "integer" },
        "pending": { "type": "integer" },
        "failed": { "type": "integer" }
      }
    },
    "generators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "dept", "task_count"],
        "properties": {
          "id": { "type": "string", "pattern": "^sop-writer-[1-7]$" },
          "dept": { "type": "string" },
          "task_count": { "type": "integer" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "dept", "chapter", "title", "status", "assigned_to"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]{3}$" },
          "dept": { "type": "string" },
          "chapter": { "type": "string", "pattern": "^Ch[0-9]{2}$" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "eval_pending", "rework", "done", "failed"]
          },
          "assigned_to": { "type": "string", "pattern": "^sop-writer-[1-7]$" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "eval_status": {
            "type": ["string", "null"],
            "enum": ["pass", "fail", null]
          },
          "output_file": { "type": "string" },
          "created_at": { "type": "string" },
          "updated_at": { "type": ["string", "null"] }
        }
      }
    }
  }
}
